{{ define "base" }}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/statics/css/app.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
    <link rel="shortcut icon" href="/statics/img/1.ico" type="image/x-icon">
    <title>{{ .Title }} - Stackriv Dev Tools</title>
</head>

<body data-page="{{ .Page }}">
    <aside class="sidebar">
        <div class="sidebar-header">
            <span class="logo">⚙️</span>
            <div>
                <h1>Dev Tools</h1>
                <p>Stackriv</p>
            </div>
        </div>
        <nav>
            <a href="/" class='nav-item {{ if eq .Page "home" }}active{{ end }}'>
                <span class="icon">🏠</span> Home
            </a>
            <p class="nav-section">Generators</p>
            <a href="/gitignore" class='nav-item {{ if eq .Page "gitignore" }}active{{ end }}'>
                <span class="icon">🚫</span> .gitignore
            </a>
            <a href="/license" class='nav-item {{ if eq .Page "license" }}active{{ end }}'>
                <span class="icon">📄</span> License
            </a>
            <a href="/packagejson" class='nav-item {{ if eq .Page "packagejson" }}active{{ end }}'>
                <span class="icon">📦</span> package.json
            </a>
            <a href="/env" class='nav-item {{ if eq .Page "env" }}active{{ end }}'>
                <span class="icon">🔐</span> .env
            </a>
            <a href="/dockerfile" class='nav-item {{ if eq .Page "dockerfile" }}active{{ end }}'>
                <span class="icon">🐳</span> Dockerfile
            </a>
            <p class="nav-section">Utilities</p>
            <a href="/uuid" class='nav-item {{if eq .Page "uuid"}}active{{end}}'>
                <span>🔑</span> UUID
            </a>
            <a href="/base64" class='nav-item {{if eq .Page "base64"}}active{{end}}'>
                <span>🔄</span> Base64
            </a>
            <a href="/hash" class='nav-item {{if eq .Page "hash"}}active{{end}}'>
                <span>#️⃣</span> Hash
            </a>
            <a href="/jwt" class='nav-item {{if eq .Page "jwt"}}active{{end}}'>
                <span>🔓</span> JWT
            </a>
            <a href="/regex" class='nav-item {{if eq .Page "regex"}}active{{end}}'>
                <span>🔍</span> Regex
            </a>

        </nav>
    </aside>

    <main class="content">
        <div class="page-header">
            <h2>{{ .Title }}</h2>
            <p class="page-desc">{{ .Description }}</p>
        </div>
        {{ block "content" . }}
        {{ end }}
    </main>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="/statics/js/app.js"></script>
</body>

</html>
{{ end }}