{{ template "base" . }}

{{define "content"}}
<div class="section-title">Generators</div>
<div class="tools-grid">
    <a href="/gitignore" class="tool-card">
        <span class="tool-icon">🚫</span>
        <h3>.gitignore Generator</h3>
        <p>Generate a .gitignore file for your project based on language and framework.</p>
    </a>
    <a href="/license" class="tool-card">
        <span class="tool-icon">📄</span>
        <h3>License Generator</h3>
        <p>Generate an open source license for your project.</p>
    </a>
    <a href="/packagejson" class="tool-card">
        <span class="tool-icon">📦</span>
        <h3>package.json Generator</h3>
        <p>Generate a package.json file for your Node.js project.</p>
    </a>
    <a href="/env" class="tool-card">
        <span class="tool-icon">🔐</span>
        <h3>.env Generator</h3>
        <p>Generate a .env template file with common environment variables.</p>
    </a>
    <a href="/dockerfile" class="tool-card">
        <span class="tool-icon">🐳</span>
        <h3>Dockerfile Generator</h3>
        <p>Generate a production-ready Dockerfile for your application.</p>
    </a>
    <a href="/readme" class="tool-card">
        <span class="tool-icon">📝</span>
        <h3>README Generator</h3>
        <p>Generate a professional README.md with badges and sections.</p>
    </a>
    <a href="/compose" class="tool-card">
        <span class="tool-icon">🗂️</span>
        <h3>Docker Compose Generator</h3>
        <p>Generate a compose.yaml for your stack.</p>
    </a>
</div>

<div class="section-title">Utilities</div>
<div class="tools-grid">
    <a href="/uuid" class="tool-card">
        <span class="tool-icon">🔑</span>
        <h3>UUID Generator</h3>
        <p>Generate random UUIDs v4 — single or bulk.</p>
    </a>
    <a href="/base64" class="tool-card">
        <span class="tool-icon">🔄</span>
        <h3>Base64 Encoder/Decoder</h3>
        <p>Encode or decode Base64 strings locally.</p>
    </a>
    <a href="/hash" class="tool-card">
        <span class="tool-icon">#️⃣</span>
        <h3>Hash Generator</h3>
        <p>Generate MD5, SHA1, SHA256 and SHA512 hashes.</p>
    </a>
    <a href="/jwt" class="tool-card">
        <span class="tool-icon">🔓</span>
        <h3>JWT Decoder</h3>
        <p>Decode and inspect a JWT token without any external service.</p>
    </a>
    <a href="/regex" class="tool-card">
        <span class="tool-icon">🔍</span>
        <h3>Regex Tester</h3>
        <p>Test your regular expressions against a string in real time.</p>
    </a>
</div>

<div class="section-title">Infrastructure</div>
<div class="tools-grid">
    <a href="/cron" class="tool-card">
        <span class="tool-icon">⏰</span>
        <h3>Cron Builder</h3>
        <p>Build and validate cron expressions visually with next run preview.</p>
    </a>
    <a href="/dns" class="tool-card">
        <span class="tool-icon">🌐</span>
        <h3>DNS Lookup</h3>
        <p>Resolve A, AAAA, MX, TXT, NS and CNAME records for any domain.</p>
    </a>
    <a href="/ssl" class="tool-card">
        <span class="tool-icon">🔒</span>
        <h3>SSL Checker</h3>
        <p>Check SSL certificate validity, issuer and expiration date.</p>
    </a>
</div>
{{end}}