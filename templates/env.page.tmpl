{{ template "base" . }}

{{define "content"}}
<div class="tool-layout">
    <div class="tool-form">
        <div class="form-group">
            <label>Preset</label>
            <div class="tags">
                <button class="tag" data-value="nodejs">Node.js</button>
                <button class="tag" data-value="go">Go</button>
                <button class="tag" data-value="django">Django</button>
                <button class="tag" data-value="database">Database</button>
                <button class="tag" data-value="jwt">JWT Auth</button>
                <button class="tag" data-value="smtp">SMTP Mail</button>
                <button class="tag" data-value="s3">S3 / MinIO</button>
                <button class="tag" data-value="docker">Docker</button>
            </div>
        </div>

        <div class="selected-tags" id="selectedTags">
            <p class="empty-state">No presets selected yet</p>
        </div>

        <div class="form-group">
            <label for="appName">App Name <span class="optional">(optional)</span></label>
            <input type="text" id="appName" class="form-input" placeholder="my-app" />
        </div>

        <button class="btn-generate" id="generateBtn" disabled>Generate .env</button>
    </div>

    <div class="tool-output" id="output" style="display:none">
        <div class="output-header">
            <span class="output-filename">.env</span>
            <button class="btn-copy" id="copyBtn">Copy</button>
        </div>
        <pre id="outputContent"></pre>
    </div>
</div>
{{end}}