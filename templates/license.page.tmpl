{{ template "base" . }}

{{define "content"}}
<div class="tool-layout">
    <div class="tool-form">
        <div class="form-group">
            <label for="licenseType">License Type</label>
            <select id="licenseType" class="form-select">
                <option value="mit">MIT</option>
                <option value="apache2">Apache 2.0</option>
                <option value="gpl3">GPL v3</option>
                <option value="bsd2">BSD 2-Clause</option>
                <option value="bsd3">BSD 3-Clause</option>
                <option value="isc">ISC</option>
                <option value="mpl2">Mozilla Public License 2.0</option>
            </select>
        </div>
        <div class="form-group">
            <label for="authorName">Author Name</label>
            <input type="text" id="authorName" class="form-input" placeholder="John Doe" />
        </div>
        <div class="form-group">
            <label for="year">Year</label>
            <input type="number" id="year" class="form-input" value="2026" />
        </div>
        <div class="form-group">
            <label for="projectName">Project Name <span class="optional">(optional)</span></label>
            <input type="text" id="projectName" class="form-input" placeholder="my-project" />
        </div>
        <button class="btn-generate" id="generateBtn">Generate License</button>
    </div>

    <div class="tool-output" id="output" style="display:none">
        <div class="output-header">
            <span class="output-filename">LICENSE</span>
            <button class="btn-copy" id="copyBtn">Copy</button>
        </div>
        <pre id="outputContent"></pre>
    </div>
</div>
{{end}}